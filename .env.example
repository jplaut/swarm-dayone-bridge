# Day One Journal Name (optional, uses default if not specified)
DAYONE_JOURNAL_NAME=

# Foursquare OAuth Credentials (for programmatic token generation)
# Get these from: https://foursquare.com/developers/apps
FOURSQUARE_CLIENT_ID=
FOURSQUARE_CLIENT_SECRET=

# Swarm API Access Token (required for sync script)
# Run 'npm run get-token' to generate this automatically
SWARM_ACCESS_TOKEN=
